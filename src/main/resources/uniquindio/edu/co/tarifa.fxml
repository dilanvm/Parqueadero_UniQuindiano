<?xml version="1.0" encoding="UTF-8"?>
        <?import javafx.geometry.Insets?>
        <?import javafx.scene.control.*?>
        <?import javafx.scene.layout.*?>
        <?import javafx.scene.text.Font?>

<VBox spacing="15.0" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uniquindio.edu.co.viewcontroller.TarifaController">
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <HBox spacing="20.0" alignment="CENTER_LEFT">
      <Button text="← Volver" onAction="#volverMenu" />
      <Label text="Gestión de Tarifas">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
   </HBox>

   <Separator />

   <VBox spacing="10.0" maxWidth="300.0" alignment="CENTER_LEFT">
      <Label text="Configurar Nueva Tarifa">
         <font><Font name="System Bold" size="14.0" /></font>
      </Label>
      <ComboBox fx:id="cbTipoVehiculo" promptText="Tipo de Vehículo" prefWidth="300.0" />
      <TextField fx:id="txtValorHora" promptText="Valor por Hora (Ej. 2500)" />
      <Button text="Guardar Tarifa" onAction="#agregarTarifa" prefWidth="300.0" />
   </VBox>

</VBox>