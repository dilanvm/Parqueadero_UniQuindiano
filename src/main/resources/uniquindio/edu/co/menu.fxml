<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="uniquindio.edu.co.viewcontroller.MenuController">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <Label text="Sistema de Parqueadero UQ">
      <font>
         <Font name="System Bold" size="24.0" />
      </font>
   </Label>

   <Label text="Seleccione el módulo a gestionar:" />

   <Button text="1. Gestión de Tarifas" onAction="#abrirTarifas" prefWidth="250.0" prefHeight="40.0" />
   <Button text="2. Gestión de Usuarios" onAction="#abrirUsuarios" prefWidth="250.0" prefHeight="40.0" />
   <Button text="3. Gestión de Espacios" onAction="#abrirEspacios" prefWidth="250.0" prefHeight="40.0" />
   <Button text="4. Gestión de Vehículos" onAction="#abrirVehiculos" prefWidth="250.0" prefHeight="40.0" />
   <Button text="5. Reportes" onAction="#abrirReportes" prefWidth="250.0" prefHeight="40.0" />
</VBox>